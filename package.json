{
  "name": "wp-sanitize",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Clean, client-side editor for WordPress PHP-serialized data. Decode to JSON, edit, re-encode — no server, no tracking.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.0",
    "codemirror": "^6.0.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@codemirror/theme-one-dark": "^6.1.3"
  }
}
